# ── LINE Bot 設定（必填）────────────────────────────────────
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token_here
LINE_CHANNEL_SECRET=your_channel_secret_here

# ── 伺服器設定 ────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── Redis 快取（選填，未設定則使用記憶體快取）────────────────
# REDIS_URL=redis://localhost:6379

# ── 農委會 Open API（預設使用公開端點，如有申請 KEY 可填入）
# COA_API_KEY=your_api_key_here
